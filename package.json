{
  "name": "openai-vscode-assistant",
  "displayName": "OpenAI VS Code Assistant",
  "description": "A personal coding assistant powered by the OpenAI API.",
  "version": "0.0.1",
  "publisher": "ayomidealaka",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:openaiAssistant.chatView",
    "onCommand:openaiAssistant.ask",
    "onCommand:openaiAssistant.explainCode",
    "onCommand:openaiAssistant.fixCode",
    "onCommand:openaiAssistant.generateTests",
    "onCommand:openaiAssistant.resetApiKey",
    "onCommand:openaiAssistant.openChat",
    "onCommand:openaiAssistant.agentMode",
    "onCommand:openaiAssistant.acceptEdits",
    "onCommand:openaiAssistant.rejectEdits",
    "onCommand:openaiAssistant.runApprovedCommand",
    "onCommand:openaiAssistant.indexWorkspace"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openaiAssistant",
          "title": "OpenAI Assistant",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "openaiAssistant": [
        {
          "id": "openaiAssistant.chatView",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "openaiAssistant.openChat",
        "title": "OpenAI Assistant: Open Chat"
      },
      {
        "command": "openaiAssistant.resetApiKey",
        "title": "OpenAI Assistant: Reset API Key"
      },
      {
        "command": "openaiAssistant.ask",
        "title": "OpenAI Assistant: Ask"
      },
      {
        "command": "openaiAssistant.explainCode",
        "title": "OpenAI Assistant: Explain Selected Code"
      },
      {
        "command": "openaiAssistant.fixCode",
        "title": "OpenAI Assistant: Fix Selected Code"
      },
      {
        "command": "openaiAssistant.generateTests",
        "title": "OpenAI Assistant: Generate Tests"
      },
      {
        "command": "openaiAssistant.agentMode",
        "title": "OpenAI Assistant: Agent Mode"
      },
      {
        "command": "openaiAssistant.acceptEdits",
        "title": "OpenAI Assistant: Accept Proposed Edits"
      },
      {
        "command": "openaiAssistant.rejectEdits",
        "title": "OpenAI Assistant: Reject Proposed Edits"
      },
      {
        "command": "openaiAssistant.runApprovedCommand",
        "title": "OpenAI Assistant: Run Approved Command"
      },
      {
        "command": "openaiAssistant.indexWorkspace",
        "title": "OpenAI Assistant: Index Workspace"
      }
    ],
    "configuration": {
      "title": "OpenAI Assistant",
      "properties": {
        "openaiAssistant.defaultModel": {
          "type": "string",
          "default": "gpt-4.1-mini",
          "description": "Default low-cost model for normal coding tasks."
        },
        "openaiAssistant.advancedModel": {
          "type": "string",
          "default": "gpt-4.1",
          "description": "Stronger model for harder debugging/refactoring tasks."
        },
        "openaiAssistant.maxOutputTokens": {
          "type": "number",
          "default": 1200,
          "description": "Maximum output tokens for assistant responses."
        },
        "openaiAssistant.enableRepoIndexing": {
          "type": "boolean",
          "default": true,
          "description": "Enable lightweight workspace indexing for assistant context."
        },
        "openaiAssistant.maxContextFiles": {
          "type": "number",
          "default": 8,
          "description": "Maximum number of related workspace files to include in assistant context."
        },
        "openaiAssistant.maxFileBytes": {
          "type": "number",
          "default": 20000,
          "description": "Maximum bytes to read from a single file for assistant context."
        },
        "openaiAssistant.enableTerminalExecution": {
          "type": "boolean",
          "default": true,
          "description": "Allow approved assistant terminal commands to run in a VS Code terminal."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node out/test/codeExtraction.test.js"
  },
  "dependencies": {
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.4.5"
  }
}
